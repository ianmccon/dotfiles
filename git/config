[core]
	editor = nano
	autocrlf = input
	quotepath = false

[init]
	defaultBranch = main

[pull]
	rebase = false
	ff = only

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[color]
	ui = auto

[alias]
	st = status -sb
	co = checkout
	br = branch -vv
	last = log -1 --stat
	lg = log --graph --decorate --oneline --all
