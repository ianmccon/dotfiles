# Listings
alias ll='ls -lah'
alias la='ls -A'

# Safer file operations
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Git
alias gs='git status'
alias gl='git log --oneline --graph --decorate -20'
alias gp='git pull'
alias gaa='git add -A'

# Python + history
alias py='python3'
alias h='history 1'

# Project shortcuts
alias matrix='cd /home/pi/matrix && source venv/bin/activate'
alias reload='source ~/.zshrc'
